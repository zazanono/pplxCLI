#!/bin/bash

if [ -f "$HOME/.secrets" ]; then
  source "$HOME/.secrets"
fi


# 1. Check arguments
if [ "$#" -lt 3 ]; then
  echo "Not enough arguments (expected >= 3, got $#)." >&2
  exit 1
fi

Mode=""

# 2. Select mode based on the first flag
case "$1" in
  -c)
    Mode="Coding mode"
    ;;
  -d)
    Mode="Debugging mode"
    ;;
  -e)
    Mode="explain mode"
    ;;
  *)
    echo "Error selecting mode (expected -c/-d/-e)" >&2
    exit 1
    ;;
esac

# 3. Shift the flag out so $1 becomes the Context
shift

CONTEXT="$1"
TASK="$2"
WORK="${3:-}"

# 4. Construct the readable User Prompt
USER_PROMPT="Task: ${TASK}
Language/tool: ${CONTEXT}"

if [ -n "$WORK" ]; then
  USER_PROMPT="${USER_PROMPT}

Code:
${WORK}"
fi

# 5. Build the JSON payload safely using jq
PAYLOAD=$(jq -n \
  --arg sys "You are an expert assistant operating in ${Mode}. Provide clear, concise answers." \
  --arg usr "$USER_PROMPT" \
  '{
    "model": "sonar",
    "stream": true,
    "return_citations": true, 
    "messages": [
      {
        "role": "system",
        "content": $sys
      },
      {
        "role": "user",
        "content": $usr
      }
    ]
  }')

# 6. Stream the response and capture the last chunk for citations
last_json=""

curl -s -N -X POST https://api.perplexity.ai/chat/completions \
  -H "Authorization: Bearer $PPLX_KEY" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD" | \
while read -r line; do
  if [[ -z "$line" ]]; then
    continue
  fi

  if [[ "$line" == *'"error"'* ]] && [[ "$line" != data:* ]]; then
    echo -e "\nAPI Error Detected:" >&2
    echo "$line" | jq '.' 2>/dev/null || echo "$line"
    exit 1
  fi

  if [[ "$line" == "data: [DONE]" ]]; then
    echo "" # Print a final newline for the text stream
    break
  fi

  if [[ "$line" == data:* ]]; then
    json_data="${line#data: }"
    last_json="$json_data" # Save the json to extract citations later
    
    # Extract text and colorize on the fly
    echo "$json_data" | jq -r -j '.choices[0].delta.content // empty'
  fi
done | sed -u -e 's/```/___TBT___/g' \
             -e "s/\*\*\([^*]*\)\*\*/$(tput bold)\1$(tput sgr0)/g" \
             -e "s/\`\([^\`]*\)\`/$(tput setaf 6)\1$(tput sgr0)/g" \
             -e "s/##* \(.*\)/$(tput setaf 5; tput bold)\1$(tput sgr0)/g" \
             -e "s/___TBT___/$(tput setaf 3)\`\`\`$(tput sgr0)/g"


# 7. Extract and Print the Citations at the end (only if they exist)
CITATIONS=$(echo "$last_json" | jq -r 'if .citations and (.citations | length > 0) then to_entries | .[] | "[\(.key + 1)] \(.value)" else empty end')

# Check if the CITATIONS variable is not empty
if [ -n "$CITATIONS" ]; then
  echo -e "\n$(tput setaf 4)Sources:$(tput sgr0)"
  echo "$CITATIONS"
fi

echo ""
